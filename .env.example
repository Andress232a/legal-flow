# ===========================================
# LegalFlow - Variables de Entorno
# ===========================================

# --- General (SECRET_KEY: misma clave en IAM, API Gateway y servicios que validan JWT) ---
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- MySQL: IAM Service ---
IAM_DB_NAME=legalflow_iam
IAM_DB_USER=legalflow
IAM_DB_PASSWORD=legalflow_secret
IAM_DB_HOST=mysql_iam
IAM_DB_PORT=3306
IAM_DB_ROOT_PASSWORD=root_secret

# --- MySQL: Document Service ---
DOC_DB_NAME=legalflow_documents
DOC_DB_USER=legalflow
DOC_DB_PASSWORD=legalflow_secret
DOC_DB_HOST=mysql_documents
DOC_DB_PORT=3306
DOC_DB_ROOT_PASSWORD=root_secret

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- MySQL: Analytics Service ---
ANALYTICS_DB_NAME=legalflow_analytics
ANALYTICS_DB_USER=legalflow
ANALYTICS_DB_PASSWORD=legalflow_secret
ANALYTICS_DB_ROOT_PASSWORD=root_secret

# --- MySQL: Client Portal Service ---
PORTAL_DB_NAME=legalflow_portal
PORTAL_DB_USER=legalflow
PORTAL_DB_PASSWORD=legalflow_secret
PORTAL_DB_ROOT_PASSWORD=root_secret

# --- Document Storage ---
DOCUMENT_STORAGE_PATH=/app/media/documents
MAX_UPLOAD_SIZE_MB=50
